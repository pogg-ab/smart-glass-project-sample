<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginHorizontal="4dp"
    android:layout_marginVertical="6dp"
    android:background="@drawable/bg_glass_card"
    android:padding="16dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Info Column -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_alignParentStart="true"
            android:layout_toStartOf="@+id/layout_signal">

            <TextView
                android:id="@+id/rcv_device_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:text="HeyCyan Smart Glasses" />

            <TextView
                android:id="@+id/rcv_device_address"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#99FFFFFF"
                android:textSize="12sp"
                android:layout_marginTop="4dp"
                android:text="71:33:1D:2C:CF:A0" />
        </LinearLayout>

        <!-- Signal Strength / RSSI Column -->
        <LinearLayout
            android:id="@+id/layout_signal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:gravity="end">

            <TextView
                android:id="@+id/rcv_device_rssi"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#00E5FF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:text="-45 dBm" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#66FFFFFF"
                android:textSize="10sp"
                android:text="Signal"
                android:layout_marginTop="2dp" />
        </LinearLayout>

    </RelativeLayout>
</LinearLayout>